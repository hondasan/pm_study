---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// サイトのベース情報
const siteName = "プロジェクトマネジメントの教科書（PMBOKガイド対応）";
const siteUrl = "https://hondasan.github.io/pm_study";
const canonicalUrl = new URL(Astro.url.pathname, "https://hondasan.github.io").toString();

// 環境変数の取得
const gaId = import.meta.env.PUBLIC_GA_ID;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;

// 章構成の定義
const tableOfContents = [
  {
    chapter: 1,
    chapterTitle: "プロジェクトマネジメントの基礎",
    sections: [
      { id: "1-1", title: "プロジェクトとは何か：定常業務との違い", path: "/pm_study/chapter1/1-1/" },
      { id: "1-2", title: "PMBOKの変遷：プロセス重視から価値重視（第7版）へ", path: "/pm_study/chapter1/1-2/" },
      { id: "1-3", title: "プロジェクトの制約条件：QCDとトレードオフ", path: "/pm_study/chapter1/1-3/" },
      { id: "1-4", title: "プロジェクト・マネジャー（PM）の役割とスキル", path: "/pm_study/chapter1/1-4/" }
    ]
  },
  {
    chapter: 2,
    chapterTitle: "プロジェクトの立ち上げ（イニシエーション）",
    sections: [
      { id: "2-1", title: "なぜ始めるのか：ビジネスケースと投資対効果（ROI）", path: "/pm_study/chapter2/2-1/" },
      { id: "2-2", title: "プロジェクトの公認：プロジェクト憲章の作成", path: "/pm_study/chapter2/2-2/" },
      { id: "2-3", title: "協力者の特定：ステークホルダー分析", path: "/pm_study/chapter2/2-3/" },
      { id: "2-4", title: "立ち上げのゴール：初期スコープと制約の明確化", path: "/pm_study/chapter2/2-4/" }
    ]
  },
  {
    chapter: 3,
    chapterTitle: "計画の策定Ⅰ：スコープとスケジュール",
    sections: [
      { id: "3-1", title: "要求の収集と定義：スコープ記述書の作成", path: "/pm_study/chapter3/3-1/" },
      { id: "3-2", title: "作業の細分化：WBS（Work Breakdown Structure）の構築", path: "/pm_study/chapter3/3-2/" },
      { id: "3-3", title: "スケジュール作成の第一歩：アクティビティの順序設定", path: "/pm_study/chapter3/3-3/" },
      { id: "3-4", title: "クリティカルパス法（CPM）とガントチャートによる期日管理", path: "/pm_study/chapter3/3-4/" }
    ]
  },
  {
    chapter: 4,
    chapterTitle: "計画の策定Ⅱ：コストと品質",
    sections: [
      { id: "4-1", title: "コスト見積もりの手法：類推・パラメータ・ボトムアップ", path: "/pm_study/chapter4/4-1/" },
      { id: "4-2", title: "予算設定とコントロール・アカウントの配置", path: "/pm_study/chapter4/4-2/" },
      { id: "4-3", title: "プロジェクトにおける品質の定義：要求品質と品質基準", path: "/pm_study/chapter4/4-3/" },
      { id: "4-4", title: "品質管理の手法：品質保証（QA）と品質管理（QC）の設計", path: "/pm_study/chapter4/4-4/" }
    ]
  },
  {
    chapter: 5,
    chapterTitle: "計画の策定Ⅲ：リスクとリソース",
    sections: [
      { id: "5-1", title: "不確実性への備え：リスクの特定と定性的・定量的分析", path: "/pm_study/chapter5/5-1/" },
      { id: "5-2", title: "リスク対応計画：回避・転嫁・軽減・受容", path: "/pm_study/chapter5/5-2/" },
      { id: "5-3", title: "チームの組織化：リソース計画と責任分担マトリクス（RACI）", path: "/pm_study/chapter5/5-3/" },
      { id: "5-4", title: "チームビルディングとリーダーシップ（タックマンモデル）", path: "/pm_study/chapter5/5-4/" }
    ]
  },
  {
    chapter: 6,
    chapterTitle: "実行と監視・コントロール（モニタリング）",
    sections: [
      { id: "6-1", title: "コミュニケーション・マネジメント：適切な相手に適切な情報を", path: "/pm_study/chapter6/6-1/" },
      { id: "6-2", title: "進捗とパフォーマンスの測定：EVM（アーンドバリュー管理）の仕組み", path: "/pm_study/chapter6/6-2/" },
      { id: "6-3", title: "プロジェクトの軌道修正：変更管理プロセスとCCB", path: "/pm_study/chapter6/6-3/" },
      { id: "6-4", title: "課題管理とコンフリクト（対立）の解決プロセス", path: "/pm_study/chapter6/6-4/" }
    ]
  },
  {
    chapter: 7,
    chapterTitle: "調達とステークホルダー・エンゲージメント",
    sections: [
      { id: "7-1", title: "自作か購入か：内外製分析とベンダー選定", path: "/pm_study/chapter7/7-1/" },
      { id: "7-2", title: "契約形態の種類：固定価格、実費償還、タイム＆マテリアル", path: "/pm_study/chapter7/7-2/" },
      { id: "7-3", title: "ステークホルダーとの協働：エンゲージメントの維持と関係構築", path: "/pm_study/chapter7/7-3/" },
      { id: "7-4", title: "期待値マネジメント：認識のズレを未然に防ぐ方法", path: "/pm_study/chapter7/7-4/" }
    ]
  },
  {
    chapter: 8,
    chapterTitle: "アジャイル手法とプロジェクトの終結",
    sections: [
      { id: "8-1", title: "アジャイルプロジェクトマネジメントの基本思想（マニフェスト）", path: "/pm_study/chapter8/8-1/" },
      { id: "8-2", title: "予測型（ウォーターフォール）と適応型（アジャイル）、ハイブリッドの使い分け", path: "/pm_study/chapter8/8-2/" },
      { id: "8-3", title: "成果物の引き渡しと評価：プロジェクトのクローズプロセス", path: "/pm_study/chapter8/8-3/" },
      { id: "8-4", title: "次回への教訓：ラーンドレジストリ（教訓集）の作成と組織資産への登録", path: "/pm_study/chapter8/8-4/" }
    ]
  }
];

// パスの正規化関数
const normalizePath = (path: string) => path.replace(/\/$/, "");

// 現在のパス
const currentNormalizedPath = normalizePath(Astro.url.pathname);

// 現在表示しているセクションおよび章を検索
let currentChapter: typeof tableOfContents[0] | undefined;
let currentSection: typeof tableOfContents[0]['sections'][0] | undefined;

for (const ch of tableOfContents) {
  const sec = ch.sections.find(s => normalizePath(s.path) === currentNormalizedPath);
  if (sec) {
    currentChapter = ch;
    currentSection = sec;
    break;
  }
}

const isHome = currentNormalizedPath === "/pm_study" || currentNormalizedPath === "/pm_study/index" || currentNormalizedPath === "/pm_study/index.html" || currentNormalizedPath === "" || currentNormalizedPath === "/index" || currentNormalizedPath === "/index.html";

// 全ての節をフラットな配列にする（ページネーション用）
const allSections = tableOfContents.reduce((acc, ch) => {
  return acc.concat(ch.sections.map(s => ({ ...s, chapterTitle: ch.chapterTitle, chapterNum: ch.chapter })));
}, [] as Array<{ id: string; title: string; path: string; chapterTitle: string; chapterNum: number }>);

// 現在のインデックスを取得
const currentIndex = allSections.findIndex(s => normalizePath(s.path) === currentNormalizedPath);

const prevSection = currentIndex > 0 ? allSections[currentIndex - 1] : null;
const nextSection = currentIndex !== -1 && currentIndex < allSections.length - 1 ? allSections[currentIndex + 1] : null;
const isLastSection = currentIndex === allSections.length - 1;

// 構造化データ（JSON-LD）の作成
let jsonLd = {};
if (isHome) {
  jsonLd = {
    "@context": "https://schema.org",
    "@type": "Book",
    "name": siteName,
    "description": "体系的で美しく、スマートフォンでも読みやすいプロジェクトマネジメントとPMBOKの入門教科書サイト。",
    "author": {
      "@type": "Person",
      "name": "プロジェクトマネジメント学習会"
    },
    "publisher": {
      "@type": "Organization",
      "name": "プロジェクトマネジメント学習会"
    },
    "url": siteUrl
  };
} else if (currentSection && currentChapter) {
  jsonLd = {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": `${currentSection.id}. ${currentSection.title}`,
    "description": description,
    "mainEntityOfPage": canonicalUrl,
    "author": {
      "@type": "Person",
      "name": "プロジェクトマネジメント学習会"
    },
    "publisher": {
      "@type": "Organization",
      "name": "プロジェクトマネジメント学習会",
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/favicon.svg`
      }
    },
    "isPartOf": {
      "@type": "WebSite",
      "name": siteName,
      "url": siteUrl
    }
  };
}
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{isHome ? siteName : `${title} | ${siteName}`}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>
  <link rel="icon" type="image/svg+xml" href="/pm_study/favicon.svg" />
  <link rel="shortcut icon" href="/pm_study/favicon.ico" />

  {/* OGPメタ情報 */}
  <meta property="og:title" content={isHome ? siteName : `${title} | ${siteName}`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={isHome ? 'website' : 'article'} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={isHome ? siteName : `${title} | ${siteName}`} />
  <meta name="twitter:description" content={description} />

  {/* Google Fonts */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Noto+Serif+JP:wght@400;700&family=Outfit:wght@400;600;700&family=Noto+Sans+JP:wght@400;700&display=swap"
    rel="stylesheet"
  />

  {/* FOUC防止用テーマ設定インラインスクリプト */}
  <script is:inline>
    (function() {
      const theme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>

  {/* JSON-LD 構造化データ */}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* Google Analytics */}
  {gaId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )}

  {/* Google AdSense */}
  {adsenseClient && (
    <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`} crossorigin="anonymous"></script>
  )}
</head>
<body>
  {/* スキップリンク */}
  <a href="#main-content" class="skip-link">メインコンテンツへスキップ</a>

  {/* 読了プログレスバー */}
  <div class="reading-progress" id="readingProgress"></div>

  {/* モバイルヘッダー */}
  <header class="mobile-header">
    <button class="menu-toggle" id="menuToggle" aria-label="メニューを開く">
      ☰
    </button>
    <div class="mobile-title">
      <a href="/pm_study/">PMの教科書</a>
    </div>
    <button class="theme-toggle-btn" id="themeToggleMobile" aria-label="テーマ切り替え" style="background: none; border: none; font-size: 1.2rem; cursor: pointer; padding: 0.5rem; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px;">☀️</button>
  </header>

  {/* モバイルメニューオーバーレイ */}
  <div class="menu-overlay" id="menuOverlay"></div>

  <div class="app-container">
    {/* サイドバー（デスクトップ時は固定、モバイル時はスライドイン） */}
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-title" style="margin-bottom: 1rem; line-height: 1.4;">
        <a href="/pm_study/">プロジェクト<br>マネジメント<br><span style="font-size: 0.9rem; font-weight: normal; color: var(--text-muted);">の教科書</span></a>
      </div>
      
      {/* テーマ切り替えボタン（サイドバー用） */}
      <div style="display: flex; justify-content: center; margin-bottom: 2rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem;">
        <button class="theme-toggle-btn" id="themeToggleSidebar" aria-label="テーマ切り替え" style="background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 20px; padding: 0.4rem 1.2rem; font-family: var(--font-sans); font-size: 0.85rem; font-weight: 600; color: var(--text-color); cursor: pointer; display: flex; align-items: center; gap: 0.5rem; transition: all 0.2s ease;">
          <span class="theme-icon">☀️</span> <span class="theme-text">ライトモード</span>
        </button>
      </div>

      <nav class="sidebar-nav">
        {tableOfContents.map((ch) => {
          const isCurrentCh = currentChapter?.chapter === ch.chapter;
          return (
            <div class="chapter-group">
              <button
                class={`chapter-toggle expanded ${isCurrentCh ? 'current-chapter' : ''}`}
                aria-expanded="true"
                type="button"
              >
                <svg class="chapter-toggle-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
                第{ch.chapter}章：{ch.chapterTitle}
              </button>
              <ul class="chapter-sections expanded">
                {ch.sections.map((sec) => {
                  const isActive = normalizePath(sec.path) === currentNormalizedPath;
                  return (
                    <li>
                      <a
                        href={sec.path}
                        class={`section-link ${isActive ? 'active' : ''}`}
                      >
                        {sec.id}. {sec.title}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          );
        })}
      </nav>
    </aside>

    {/* メインコンテンツ */}
    <div class="main-wrapper">
      <main class="main-content" id="main-content">
        {/* ブレッドクラム（パンくずリスト） */}
        {!isHome && currentChapter && currentSection && (
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/pm_study/">ホーム</a>
            <span>＞</span>
            <span>第{currentChapter.chapter}章: {currentChapter.chapterTitle}</span>
            <span>＞</span>
            <span>{currentSection.id}. {currentSection.title}</span>
          </nav>
        )}

        {/* 広告プレースホルダー（Google AdSenseクライアント定義時のみ表示） */}
        {adsenseClient && (
          <div class="adsense-placeholder" style="margin-bottom: 2rem; padding: 1rem; border: 1px dashed var(--border-color); text-align: center; font-size: 0.8rem; color: var(--text-muted); background: var(--white);">
            [スポンサーリンク - Google AdSense]
          </div>
        )}

        {/* 本文コンテンツ */}
        <article>
          <slot />
        </article>

        {/* 広告プレースホルダー（下部） */}
        {adsenseClient && (
          <div class="adsense-placeholder" style="margin-top: 3rem; padding: 1rem; border: 1px dashed var(--border-color); text-align: center; font-size: 0.8rem; color: var(--text-muted); background: var(--white);">
            [スポンサーリンク - Google AdSense]
          </div>
        )}

        {/* ページネーション（ページ送り） */}
        {!isHome && (
          <nav class="pagination" aria-label="ページ送り">
            {prevSection ? (
              <a href={prevSection.path} class="pagination-btn prev">
                <span class="direction">前へ</span>
                <span class="title">{prevSection.id}. {prevSection.title}</span>
              </a>
            ) : (
              <a href="/pm_study/" class="pagination-btn prev">
                <span class="direction">前へ</span>
                <span class="title">ホームへ戻る</span>
              </a>
            )}

            {isLastSection ? (
              <a href="/pm_study/" class="pagination-btn next center">
                <span class="direction">読了</span>
                <span class="title" style="font-weight: bold;">読了：ホームへ戻る</span>
              </a>
            ) : nextSection ? (
              <a href={nextSection.path} class="pagination-btn next">
                <span class="direction">次へ</span>
                <span class="title">{nextSection.id}. {nextSection.title}</span>
              </a>
            ) : null}
          </nav>
        )}
      </main>
    </div>
  </div>

  {/* フッター */}
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-nav">
        <a href="/pm_study/">ホーム</a>
        <span class="footer-sep">|</span>
        <a href="/pm_study/chapter1/1-1/">学習を始める</a>
      </div>
      <p class="footer-copyright">
        © 2026 プロジェクトマネジメント学習会. 学習目的で自由にご活用ください.
      </p>
      <p class="footer-powered">
        Built with <a href="https://astro.build/" target="_blank" rel="noopener">Astro</a>
      </p>
    </div>
  </footer>

  {/* トップへ戻るボタン */}
  <button class="scroll-to-top" id="scrollToTop" aria-label="ページトップへ戻る" title="トップへ戻る">
    ↑
  </button>

  {/* クライアントスクリプト */}
  <script>
    // 1. モバイルメニューの制御
    const menuToggle = document.getElementById('menuToggle');
    const sidebar = document.getElementById('sidebar');
    const menuOverlay = document.getElementById('menuOverlay');

    function toggleMenu() {
      const isActive = sidebar?.classList.toggle('active');
      menuOverlay?.classList.toggle('active', isActive);
      if (isActive) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    }

    menuToggle?.addEventListener('click', toggleMenu);
    menuOverlay?.addEventListener('click', toggleMenu);

    // 2. レスポンシブテーブルの制御（600px以下でのカード化）
    function handleResponsiveTables() {
      const tables = document.querySelectorAll('table.responsive-table');
      const isMobile = window.innerWidth <= 600;

      tables.forEach((table) => {
        if (!(table instanceof HTMLTableElement)) return;

        // 条件判定：列数が4以上、または30文字以上のセルが1つでもあるか
        const headers = table.querySelectorAll('thead th');
        const cells = table.querySelectorAll('tbody td');
        
        let shouldCardify = headers.length >= 4;

        if (!shouldCardify) {
          for (let cell of cells) {
            if (cell.textContent && cell.textContent.trim().length >= 30) {
              shouldCardify = true;
              break;
            }
          }
        }

        // 条件に当てはまらない、またはモバイル画面でない場合はカード化を解除
        if (!shouldCardify || !isMobile) {
          table.classList.remove('card-ified');
          // 元のDOM構造に戻す（もし書き換えられていれば）
          const cardValues = table.querySelectorAll('td .card-value');
          if (cardValues.length > 0) {
            table.querySelectorAll('tbody tr').forEach((tr) => {
              tr.querySelectorAll('td').forEach((td) => {
                const valueSpan = td.querySelector('.card-value');
                if (valueSpan) {
                  td.innerHTML = valueSpan.innerHTML;
                }
              });
            });
          }
          return;
        }

        // カード化する
        table.classList.add('card-ified');

        // ヘッダーテキストを取得
        const headerTexts: string[] = [];
        headers.forEach((th) => {
          headerTexts.push(th.textContent?.trim() || '');
        });

        // 各行の各セルに [見出し] と [値] のラッパーを追加
        const rows = table.querySelectorAll('tbody tr');
        rows.forEach((tr) => {
          const cellsInRow = tr.querySelectorAll('td');
          cellsInRow.forEach((td, index) => {
            // すでにカード化用の要素があるか確認
            if (td.querySelector('.card-header')) return;

            const headerName = headerTexts[index] || `列 ${index + 1}`;
            const originalContent = td.innerHTML;

            td.innerHTML = `
              <span class="card-header">[${headerName}]</span>
              <span class="card-value">${originalContent}</span>
            `;
          });
        });
      });
    }

    // 3. スクロール連動フェードイン (Intersection Observer)
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -60px 0px',
      threshold: 0.1
    };

    const fadeObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          fadeObserver.unobserve(entry.target);
        }
      });
    }, observerOptions);

    function initScrollFade() {
      document.querySelectorAll('article h2, article h3, .diagram-container, .note-box, table.responsive-table').forEach(el => {
        el.classList.add('fade-in-target');
        fadeObserver.observe(el);
      });
    }

    // 4. サイドバーアコーディオン
    function initSidebarAccordion() {
      document.querySelectorAll('.chapter-toggle').forEach(toggle => {
        toggle.addEventListener('click', () => {
          const isExpanded = toggle.classList.toggle('expanded');
          toggle.setAttribute('aria-expanded', isExpanded.toString());
          const sections = toggle.nextElementSibling;
          if (sections) {
            sections.classList.toggle('expanded');
          }
        });
      });
    }

    // 5. 読了プログレスバー
    const progressBar = document.getElementById('readingProgress');
    function handleProgressBar() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      if (progressBar) {
        progressBar.style.width = progress + '%';
      }
    }

    // 6. スクロールトップボタン
    const scrollBtn = document.getElementById('scrollToTop');
    function handleScrollTopButton() {
      if (scrollBtn) {
        scrollBtn.classList.toggle('visible', window.scrollY > 400);
      }
    }

    scrollBtn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // 7. ページ内目次（Table of Contents）の自動生成
    function generateTOC() {
      const article = document.querySelector('article');
      if (!article) return;
      
      const headings = article.querySelectorAll('h2, h3');
      if (headings.length < 3) return; // 見出し数が少ないページでは表示しない
      
      // すでにTOCが存在する場合は作成しない
      if (article.querySelector('.page-toc')) return;

      const tocContainer = document.createElement('nav');
      tocContainer.className = 'page-toc';
      tocContainer.setAttribute('aria-label', 'ページ内目次');
      
      const tocTitle = document.createElement('div');
      tocTitle.className = 'page-toc-title';
      tocTitle.textContent = 'このページの内容';
      tocContainer.appendChild(tocTitle);
      
      const tocList = document.createElement('ul');
      tocList.className = 'page-toc-list';
      
      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id = `section-${index}`;
        }
        
        const li = document.createElement('li');
        li.className = heading.tagName === 'H3' ? 'toc-h3' : 'toc-h2';
        
        const a = document.createElement('a');
        a.href = `#${heading.id}`;
        a.textContent = heading.textContent || '';
        a.addEventListener('click', (e) => {
          e.preventDefault();
          heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        
        li.appendChild(a);
        tocList.appendChild(li);
      });
      
      tocContainer.appendChild(tocList);
      
      const h1 = article.querySelector('h1');
      if (h1 && h1.nextSibling) {
        h1.parentNode?.insertBefore(tocContainer, h1.nextSibling);
      }
    }

    // 8. ダークモードの制御
    const themeToggleMobile = document.getElementById('themeToggleMobile');
    const themeToggleSidebar = document.getElementById('themeToggleSidebar');

    function updateThemeUI(theme: string) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);

      const isDark = theme === 'dark';
      
      // モバイルボタン更新
      if (themeToggleMobile) {
        themeToggleMobile.textContent = isDark ? '🌙' : '☀️';
      }

      // サイドバーボタン更新
      if (themeToggleSidebar) {
        const iconSpan = themeToggleSidebar.querySelector('.theme-icon');
        const textSpan = themeToggleSidebar.querySelector('.theme-text');
        if (iconSpan) iconSpan.textContent = isDark ? '🌙' : '☀️';
        if (textSpan) textSpan.textContent = isDark ? 'ダークモード' : 'ライトモード';
      }
    }

    function initTheme() {
      const savedTheme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      updateThemeUI(savedTheme);

      const handleToggle = () => {
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        updateThemeUI(newTheme);
      };

      themeToggleMobile?.addEventListener('click', handleToggle);
      themeToggleSidebar?.addEventListener('click', handleToggle);
    }

    // 9. サイドバーの自動スクロール（アクティブな項目を可視化）
    function initSidebarScroll() {
      const sidebar = document.getElementById('sidebar');
      const activeLink = document.querySelector('.sidebar .section-link.active');
      
      if (sidebar && activeLink) {
        // 要素の画面上の位置を取得
        const sidebarRect = sidebar.getBoundingClientRect();
        const activeRect = activeLink.getBoundingClientRect();
        
        // アクティブな要素がサイドバーの中央付近にくるようにスクロール位置を調整
        // （ページロード時の初期位置合わせ用）
        sidebar.scrollTop = sidebar.scrollTop + (activeRect.top - sidebarRect.top) - (sidebar.clientHeight / 2) + (activeRect.height / 2);
      }
    }

    // スクロールイベントハンドラーの登録
    window.addEventListener('scroll', () => {
      handleProgressBar();
      handleScrollTopButton();
    }, { passive: true });

    // 初期化処理の実行
    function init() {
      handleResponsiveTables();
      initScrollFade();
      initSidebarAccordion();
      generateTOC();
      initTheme();
      initSidebarScroll();
    }

    // 初回ロード
    init();

    // ウィンドウリサイズ時
    window.addEventListener('resize', handleResponsiveTables);
  </script>
</body>
</html>
